From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: patch-ci <ci@localhost>
Date: Tue, 7 Jul 2026 09:27:06 +0000
Subject: [PATCH] fix(docker): add fish and shell completions


diff --git a/docker/base/Dockerfile b/docker/base/Dockerfile
index 30916a7ed..af2eeba1f 100644
--- a/docker/base/Dockerfile
+++ b/docker/base/Dockerfile
@@ -68,8 +68,10 @@ RUN set -eux; \
     apt-get update; \
     apt-get install -y --no-install-recommends \
       bash \
+      bash-completion \
       bubblewrap \
       fd-find \
+      fish \
       gh \
       git \
       gosu \
@@ -118,7 +120,9 @@ RUN set -eux; \
     node --version; \
     npm --version; \
     corepack --version; \
+    fish --version; \
     gh --version | head -n 1; \
+    test -f /usr/share/bash-completion/bash_completion; \
     command -v inotifywait >/dev/null; \
     uv --version; \
     rm -rf /var/lib/apt/lists/*
