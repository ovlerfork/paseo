From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Herbrant <cdavide98carnemolla@gmail.com>
Date: Thu, 4 Jun 2026 11:18:30 +0200
Subject: [PATCH] fix(docker): default home to /home/paseo


diff --git a/docker/README.md b/docker/README.md
index b40c52b7..76384e7a 100644
--- a/docker/README.md
+++ b/docker/README.md
@@ -19,13 +19,18 @@ docker run -d --name paseo \
   -e PASEO_PASSWORD=change-me \
   -e DOCKER_MODS=ghcr.io/getpaseo/mods:claude-code \
   -e ANTHROPIC_API_KEY=sk-ant-... \
-  -v "$PWD/paseo-config:/config" \
+  -v "$PWD/paseo-home:/home/paseo" \
   -v "$PWD:/workspace" \
   ghcr.io/getpaseo/paseo:debian
 ```
 
 Then point the Paseo app/CLI at `http://<host>:6767`.
 
+The default persistent home is `/home/paseo`. To use another path, set
+`PASEO_HOME` and mount that same path, for example
+`-e PASEO_HOME=/config -v "$PWD/paseo-config:/config"`. Existing `/config`
+deployments must opt in this way; the image does not fall back automatically.
+
 On startup the container prints a pairing QR code and link to its logs once the
 daemon is listening — run `docker logs paseo` and scan it with the Paseo app.
 Set `-e PASEO_PAIRING_QR=0` to disable.
diff --git a/docker/base/Dockerfile b/docker/base/Dockerfile
index e0101561..5cbd2a07 100644
--- a/docker/base/Dockerfile
+++ b/docker/base/Dockerfile
@@ -18,14 +18,14 @@ ARG S6_OVERLAY_VERSION=3.2.0.2
 # Paseo version to install from npm. Defaults to latest; CI pins to the release version.
 ARG PASEO_VERSION=latest
 
-ENV PASEO_HOME=/config \
-    HOME=/config \
+ENV PASEO_HOME=/home/paseo \
+    HOME=/home/paseo \
     PASEO_LISTEN=0.0.0.0:6767 \
-    CLAUDE_CONFIG_DIR=/config/.claude \
-    CODEX_HOME=/config/.codex \
-    XDG_CONFIG_HOME=/config/.config \
-    XDG_DATA_HOME=/config/.local/share \
-    XDG_CACHE_HOME=/config/.cache \
+    CLAUDE_CONFIG_DIR=/home/paseo/.claude \
+    CODEX_HOME=/home/paseo/.codex \
+    XDG_CONFIG_HOME=/home/paseo/.config \
+    XDG_DATA_HOME=/home/paseo/.local/share \
+    XDG_CACHE_HOME=/home/paseo/.cache \
     ONNXRUNTIME_NODE_INSTALL=skip \
     PUID=911 \
     PGID=911 \
@@ -62,10 +62,10 @@ RUN PASEO_VERSION="${PASEO_VERSION}" /tmp/install-paseo.sh && rm -f /tmp/install
 RUN set -eux; \
     if [ -f /etc/alpine-release ]; then \
       addgroup -g 911 paseo; \
-      adduser -D -H -u 911 -G paseo -s /sbin/nologin paseo; \
+      adduser -D -H -h /home/paseo -u 911 -G paseo -s /sbin/nologin paseo; \
     else \
       groupadd -g 911 paseo; \
-      useradd -u 911 -g paseo -M -s /usr/sbin/nologin paseo; \
+      useradd -u 911 -g paseo -d /home/paseo -M -s /usr/sbin/nologin paseo; \
     fi
 
 # s6 service definitions, the docker-mods loader and the daemon launcher.
@@ -81,7 +81,7 @@ RUN set -eux; \
       /etc/s6-overlay/s6-rc.d/svc-paseo-pair/run
 
 EXPOSE 6767
-VOLUME /config
+VOLUME /home/paseo
 
 HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
   CMD node -e "require('net').connect(6767,'127.0.0.1').on('connect',function(){process.exit(0)}).on('error',function(){process.exit(1)})" || exit 1
diff --git a/docker/base/rootfs/etc/s6-overlay/s6-rc.d/init-paseo/run b/docker/base/rootfs/etc/s6-overlay/s6-rc.d/init-paseo/run
index a966fdeb..553ede1d 100755
--- a/docker/base/rootfs/etc/s6-overlay/s6-rc.d/init-paseo/run
+++ b/docker/base/rootfs/etc/s6-overlay/s6-rc.d/init-paseo/run
@@ -1,5 +1,5 @@
 #!/command/with-contenv bash
-# Seed the /config volume and align the paseo user with the host volume owner.
+# Seed PASEO_HOME and align the paseo user with the host volume owner.
 set -euo pipefail
 
 PUID="${PUID:-911}"
@@ -26,9 +26,26 @@ case "$(printf '%s' "${PASEO_ENABLE_SUDO:-}" | tr '[:upper:]' '[:lower:]')" in
     ;;
 esac
 
-PASEO_HOME="${PASEO_HOME:-/config}"
+DEFAULT_PASEO_HOME="/home/paseo"
+PASEO_HOME="${PASEO_HOME:-$DEFAULT_PASEO_HOME}"
 mkdir -p "$PASEO_HOME"
 
+home_scoped_dir() {
+  local name="$1"
+  local suffix="$2"
+  local image_default="${DEFAULT_PASEO_HOME}${suffix}"
+  local value="${!name:-}"
+  if [[ -z "$value" || ( "$PASEO_HOME" != "$DEFAULT_PASEO_HOME" && "$value" == "$image_default" ) ]]; then
+    printf -v "$name" '%s' "${PASEO_HOME}${suffix}"
+  fi
+}
+
+home_scoped_dir CLAUDE_CONFIG_DIR "/.claude"
+home_scoped_dir CODEX_HOME "/.codex"
+home_scoped_dir XDG_CONFIG_HOME "/.config"
+home_scoped_dir XDG_DATA_HOME "/.local/share"
+home_scoped_dir XDG_CACHE_HOME "/.cache"
+
 ensure_paseo_dir() {
   local dir="$1"
   local mode="${2:-700}"
@@ -53,12 +70,12 @@ ensure_paseo_dir() {
 }
 
 # Only chown the top level + small paseo-owned config dirs; avoid clobbering a
-# large bind-mounted /config on every boot.
+# large bind-mounted PASEO_HOME on every boot.
 ensure_paseo_dir "$PASEO_HOME" 700
-ensure_paseo_dir "${CLAUDE_CONFIG_DIR:-${PASEO_HOME}/.claude}" 700
-ensure_paseo_dir "${CODEX_HOME:-${PASEO_HOME}/.codex}" 700
-ensure_paseo_dir "${XDG_CONFIG_HOME:-${PASEO_HOME}/.config}" 700
-ensure_paseo_dir "${XDG_DATA_HOME:-${PASEO_HOME}/.local/share}" 700
-ensure_paseo_dir "${XDG_CACHE_HOME:-${PASEO_HOME}/.cache}" 700
+ensure_paseo_dir "$CLAUDE_CONFIG_DIR" 700
+ensure_paseo_dir "$CODEX_HOME" 700
+ensure_paseo_dir "$XDG_CONFIG_HOME" 700
+ensure_paseo_dir "$XDG_DATA_HOME" 700
+ensure_paseo_dir "$XDG_CACHE_HOME" 700
 
-echo "[init] /config ready (PUID=${PUID} PGID=${PGID} home=${PASEO_HOME})"
+echo "[init] PASEO_HOME ready (PUID=${PUID} PGID=${PGID} home=${PASEO_HOME})"
diff --git a/docker/base/rootfs/etc/s6-overlay/s6-rc.d/svc-paseo-pair/run b/docker/base/rootfs/etc/s6-overlay/s6-rc.d/svc-paseo-pair/run
index 8954b0eb..f0fcb6b8 100755
--- a/docker/base/rootfs/etc/s6-overlay/s6-rc.d/svc-paseo-pair/run
+++ b/docker/base/rootfs/etc/s6-overlay/s6-rc.d/svc-paseo-pair/run
@@ -3,6 +3,10 @@
 # can scan it straight from `docker logs`. Best-effort: never fail the boot.
 set -uo pipefail
 
+: "${PASEO_HOME:=/home/paseo}"
+export PASEO_HOME
+export HOME="$PASEO_HOME"
+
 # Allow opting out: PASEO_PAIRING_QR in {0,false,no,off} skips the QR.
 case "$(printf '%s' "${PASEO_PAIRING_QR:-}" | tr '[:upper:]' '[:lower:]')" in
   0 | false | no | n | off)
@@ -30,7 +34,7 @@ if [[ "$ready" -ne 1 ]]; then
   exit 0
 fi
 
-# Drop to the unprivileged paseo user (owns /config). Never fail the boot.
+# Drop to the unprivileged paseo user (owns PASEO_HOME). Never fail the boot.
 s6-setuidgid paseo paseo daemon pair || \
   echo "[pair] failed to generate pairing QR (relay disabled?); continuing." >&2
 
diff --git a/docker/base/rootfs/usr/local/bin/paseo-run b/docker/base/rootfs/usr/local/bin/paseo-run
index 1c56c39b..5c50ae55 100755
--- a/docker/base/rootfs/usr/local/bin/paseo-run
+++ b/docker/base/rootfs/usr/local/bin/paseo-run
@@ -3,9 +3,28 @@
 # Runs as the unprivileged `paseo` user (svc-paseo applies s6-setuidgid).
 set -euo pipefail
 
-: "${PASEO_HOME:=/config}"
+DEFAULT_PASEO_HOME="/home/paseo"
+: "${PASEO_HOME:=$DEFAULT_PASEO_HOME}"
 export PASEO_HOME
 export HOME="$PASEO_HOME"
+
+home_scoped_env() {
+  local name="$1"
+  local suffix="$2"
+  local image_default="${DEFAULT_PASEO_HOME}${suffix}"
+  local value="${!name:-}"
+  if [[ -z "$value" || ( "$PASEO_HOME" != "$DEFAULT_PASEO_HOME" && "$value" == "$image_default" ) ]]; then
+    printf -v "$name" '%s' "${PASEO_HOME}${suffix}"
+  fi
+  export "$name"
+}
+
+home_scoped_env CLAUDE_CONFIG_DIR "/.claude"
+home_scoped_env CODEX_HOME "/.codex"
+home_scoped_env XDG_CONFIG_HOME "/.config"
+home_scoped_env XDG_DATA_HOME "/.local/share"
+home_scoped_env XDG_CACHE_HOME "/.cache"
+
 : "${PASEO_LISTEN:=0.0.0.0:6767}"
 export PASEO_LISTEN
 
