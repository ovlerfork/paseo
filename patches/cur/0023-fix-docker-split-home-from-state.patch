From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Herbrant <cdavide98carnemolla@gmail.com>
Date: Sun, 7 Jun 2026 12:26:49 +0200
Subject: [PATCH] fix(docker): split home from state

Docker images now keep HOME at /home/paseo and store Paseo daemon state under /home/paseo/.paseo by default.

Existing volumes can keep the old layout by setting PASEO_HOME=/home/paseo.

diff --git a/docker/README.md b/docker/README.md
index 04833060..8d2e8c40 100644
--- a/docker/README.md
+++ b/docker/README.md
@@ -27,10 +27,16 @@ docker run -d --name paseo \
 
 Then point the Paseo app/CLI at `http://<host>:6767`.
 
-The default persistent home is `/home/paseo`. To use another path, set
-`PASEO_HOME` and mount that same path, for example
+The default persistent user home is `/home/paseo`; Paseo daemon state lives in
+`/home/paseo/.paseo`, while agent config stays in paths like `/home/paseo/.codex`
+and `/home/paseo/.claude`. To store daemon state elsewhere, set `PASEO_HOME` and
+mount that same path, for example
 `-e PASEO_HOME=/var/lib/paseo -v paseo-state:/var/lib/paseo`.
 
+Older images stored daemon state directly in `/home/paseo`. Existing volumes
+with that layout should either set `-e PASEO_HOME=/home/paseo` or move the old
+Paseo files into `/home/paseo/.paseo`.
+
 On startup the container prints a pairing QR code and link to its logs once the
 daemon is listening — run `docker logs paseo` and scan it with the Paseo app.
 Set `-e PASEO_PAIRING_QR=0` to disable.
diff --git a/docker/base/Dockerfile b/docker/base/Dockerfile
index ccef4582..0e5bf724 100644
--- a/docker/base/Dockerfile
+++ b/docker/base/Dockerfile
@@ -18,8 +18,8 @@ ARG S6_OVERLAY_VERSION=3.2.0.2
 # Paseo version to install from npm. Defaults to latest; CI pins to the release version.
 ARG PASEO_VERSION=latest
 
-ENV PASEO_HOME=/home/paseo \
-    HOME=/home/paseo \
+ENV HOME=/home/paseo \
+    PASEO_HOME=/home/paseo/.paseo \
     PASEO_LISTEN=0.0.0.0:6767 \
     CLAUDE_CONFIG_DIR=/home/paseo/.claude \
     CODEX_HOME=/home/paseo/.codex \
diff --git a/docker/base/rootfs/etc/s6-overlay/s6-rc.d/init-paseo/run b/docker/base/rootfs/etc/s6-overlay/s6-rc.d/init-paseo/run
index af8b0163..74ea10f9 100755
--- a/docker/base/rootfs/etc/s6-overlay/s6-rc.d/init-paseo/run
+++ b/docker/base/rootfs/etc/s6-overlay/s6-rc.d/init-paseo/run
@@ -26,18 +26,21 @@ case "$(printf '%s' "${PASEO_ENABLE_SUDO:-}" | tr '[:upper:]' '[:lower:]')" in
     ;;
 esac
 
-DEFAULT_PASEO_HOME="/home/paseo"
-PASEO_HOME="${PASEO_HOME:-$DEFAULT_PASEO_HOME}"
-mkdir -p "$PASEO_HOME"
-usermod -d "$PASEO_HOME" paseo || true
+IMAGE_DEFAULT_HOME="/home/paseo"
+IMAGE_DEFAULT_PASEO_HOME="${IMAGE_DEFAULT_HOME}/.paseo"
+CONTAINER_HOME="${HOME:-$IMAGE_DEFAULT_HOME}"
+if [[ -z "${PASEO_HOME:-}" || ( "$CONTAINER_HOME" != "$IMAGE_DEFAULT_HOME" && "${PASEO_HOME:-}" == "$IMAGE_DEFAULT_PASEO_HOME" ) ]]; then
+  PASEO_HOME="${CONTAINER_HOME}/.paseo"
+fi
+usermod -d "$CONTAINER_HOME" paseo || true
 
 home_scoped_dir() {
   local name="$1"
   local suffix="$2"
-  local image_default="${DEFAULT_PASEO_HOME}${suffix}"
+  local image_default="${IMAGE_DEFAULT_HOME}${suffix}"
   local value="${!name:-}"
-  if [[ -z "$value" || ( "$PASEO_HOME" != "$DEFAULT_PASEO_HOME" && "$value" == "$image_default" ) ]]; then
-    printf -v "$name" '%s' "${PASEO_HOME}${suffix}"
+  if [[ -z "$value" || ( "$CONTAINER_HOME" != "$IMAGE_DEFAULT_HOME" && "$value" == "$image_default" ) ]]; then
+    printf -v "$name" '%s' "${CONTAINER_HOME}${suffix}"
   fi
 }
 
@@ -48,37 +51,26 @@ home_scoped_dir XDG_DATA_HOME "/.local/share"
 home_scoped_dir XDG_STATE_HOME "/.local/state"
 home_scoped_dir XDG_CACHE_HOME "/.cache"
 
-ensure_paseo_dir() {
+ensure_owned_dir() {
   local dir="$1"
   local mode="${2:-700}"
-  local existed=0
   if [[ -z "$dir" ]]; then
     return 0
   fi
-  [[ -d "$dir" ]] && existed=1
   mkdir -p "$dir"
-  case "$dir" in
-    "$PASEO_HOME" | "$PASEO_HOME"/*)
-      chown paseo:paseo "$dir" || true
-      chmod "$mode" "$dir" || true
-      ;;
-    *)
-      if [[ "$existed" == 0 ]]; then
-        chown paseo:paseo "$dir" || true
-        chmod "$mode" "$dir" || true
-      fi
-      ;;
-  esac
+  chown paseo:paseo "$dir" || true
+  chmod "$mode" "$dir" || true
 }
 
-# Only chown the top level + small paseo-owned config dirs; avoid clobbering a
-# large bind-mounted PASEO_HOME on every boot.
-ensure_paseo_dir "$PASEO_HOME" 700
-ensure_paseo_dir "$CLAUDE_CONFIG_DIR" 700
-ensure_paseo_dir "$CODEX_HOME" 700
-ensure_paseo_dir "$XDG_CONFIG_HOME" 700
-ensure_paseo_dir "$XDG_DATA_HOME" 700
-ensure_paseo_dir "$XDG_STATE_HOME" 700
-ensure_paseo_dir "$XDG_CACHE_HOME" 700
+# Only chown directory entries, not their contents; avoid clobbering large
+# bind-mounted homes while still making the expected roots writable.
+ensure_owned_dir "$CONTAINER_HOME" 700
+ensure_owned_dir "$PASEO_HOME" 700
+ensure_owned_dir "$CLAUDE_CONFIG_DIR" 700
+ensure_owned_dir "$CODEX_HOME" 700
+ensure_owned_dir "$XDG_CONFIG_HOME" 700
+ensure_owned_dir "$XDG_DATA_HOME" 700
+ensure_owned_dir "$XDG_STATE_HOME" 700
+ensure_owned_dir "$XDG_CACHE_HOME" 700
 
-echo "[init] PASEO_HOME ready (PUID=${PUID} PGID=${PGID} home=${PASEO_HOME})"
+echo "[init] Paseo paths ready (PUID=${PUID} PGID=${PGID} HOME=${CONTAINER_HOME} PASEO_HOME=${PASEO_HOME})"
diff --git a/docker/base/rootfs/usr/local/bin/paseo-run b/docker/base/rootfs/usr/local/bin/paseo-run
index 0e2e86fd..61414adb 100755
--- a/docker/base/rootfs/usr/local/bin/paseo-run
+++ b/docker/base/rootfs/usr/local/bin/paseo-run
@@ -3,18 +3,22 @@
 # Runs as the unprivileged `paseo` user (svc-paseo applies s6-setuidgid).
 set -euo pipefail
 
-DEFAULT_PASEO_HOME="/home/paseo"
-: "${PASEO_HOME:=$DEFAULT_PASEO_HOME}"
+IMAGE_DEFAULT_HOME="/home/paseo"
+IMAGE_DEFAULT_PASEO_HOME="${IMAGE_DEFAULT_HOME}/.paseo"
+: "${HOME:=$IMAGE_DEFAULT_HOME}"
+if [[ -z "${PASEO_HOME:-}" || ( "$HOME" != "$IMAGE_DEFAULT_HOME" && "${PASEO_HOME:-}" == "$IMAGE_DEFAULT_PASEO_HOME" ) ]]; then
+  PASEO_HOME="${HOME}/.paseo"
+fi
+export HOME
 export PASEO_HOME
-export HOME="$PASEO_HOME"
 
 home_scoped_env() {
   local name="$1"
   local suffix="$2"
-  local image_default="${DEFAULT_PASEO_HOME}${suffix}"
+  local image_default="${IMAGE_DEFAULT_HOME}${suffix}"
   local value="${!name:-}"
-  if [[ -z "$value" || ( "$PASEO_HOME" != "$DEFAULT_PASEO_HOME" && "$value" == "$image_default" ) ]]; then
-    printf -v "$name" '%s' "${PASEO_HOME}${suffix}"
+  if [[ -z "$value" || ( "$HOME" != "$IMAGE_DEFAULT_HOME" && "$value" == "$image_default" ) ]]; then
+    printf -v "$name" '%s' "${HOME}${suffix}"
   fi
   export "$name"
 }
@@ -23,6 +27,7 @@ home_scoped_env CLAUDE_CONFIG_DIR "/.claude"
 home_scoped_env CODEX_HOME "/.codex"
 home_scoped_env XDG_CONFIG_HOME "/.config"
 home_scoped_env XDG_DATA_HOME "/.local/share"
+home_scoped_env XDG_STATE_HOME "/.local/state"
 home_scoped_env XDG_CACHE_HOME "/.cache"
 
 : "${PASEO_LISTEN:=0.0.0.0:6767}"
