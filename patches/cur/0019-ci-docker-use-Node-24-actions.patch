From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Herbrant <cdavide98carnemolla@gmail.com>
Date: Fri, 5 Jun 2026 13:43:32 +0200
Subject: [PATCH] ci(docker): use Node 24 actions


diff --git a/.github/workflows/docker.yml b/.github/workflows/docker.yml
index 226806b0..cb2142ab 100644
--- a/.github/workflows/docker.yml
+++ b/.github/workflows/docker.yml
@@ -33,7 +33,7 @@ jobs:
       push: ${{ steps.v.outputs.push }}
       owner: ${{ steps.v.outputs.owner }}
     steps:
-      - uses: actions/checkout@v4
+      - uses: actions/checkout@v6
       - id: v
         run: |
           set -euo pipefail
@@ -82,7 +82,7 @@ jobs:
             moving: arch
             platforms: linux/amd64
     steps:
-      - uses: actions/checkout@v4
+      - uses: actions/checkout@v6
 
       - name: Compute tags
         id: tags
@@ -105,20 +105,20 @@ jobs:
           } >> "$GITHUB_OUTPUT"
 
       - if: matrix.name != 'arch'
-        uses: docker/setup-qemu-action@v3
+        uses: docker/setup-qemu-action@v4
       - if: matrix.name != 'arch'
-        uses: docker/setup-buildx-action@v3
+        uses: docker/setup-buildx-action@v4
 
       - name: Log in to GHCR
         if: needs.setup.outputs.push == 'true'
-        uses: docker/login-action@v3
+        uses: docker/login-action@v4
         with:
           registry: ${{ env.REGISTRY }}
           username: ${{ github.actor }}
           password: ${{ secrets.GITHUB_TOKEN }}
 
       - if: matrix.name != 'arch'
-        uses: docker/build-push-action@v6
+        uses: docker/build-push-action@v7
         with:
           context: docker/base
           file: docker/base/Dockerfile
@@ -172,20 +172,20 @@ jobs:
       matrix:
         agent: [claude-code, codex, copilot, opencode, pi]
     steps:
-      - uses: actions/checkout@v4
+      - uses: actions/checkout@v6
 
-      - uses: docker/setup-qemu-action@v3
-      - uses: docker/setup-buildx-action@v3
+      - uses: docker/setup-qemu-action@v4
+      - uses: docker/setup-buildx-action@v4
 
       - name: Log in to GHCR
         if: needs.setup.outputs.push == 'true'
-        uses: docker/login-action@v3
+        uses: docker/login-action@v4
         with:
           registry: ${{ env.REGISTRY }}
           username: ${{ github.actor }}
           password: ${{ secrets.GITHUB_TOKEN }}
 
-      - uses: docker/build-push-action@v6
+      - uses: docker/build-push-action@v7
         with:
           context: docker/mods/${{ matrix.agent }}
           file: docker/mods/${{ matrix.agent }}/Dockerfile
