From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: patch-ci <ci@localhost>
Date: Thu, 9 Jul 2026 18:23:14 +0000
Subject: [PATCH] fix(docker): pin mod package versions


diff --git a/docker/mods/claude-code/Dockerfile b/docker/mods/claude-code/Dockerfile
index 0c908e14b..f287d0d49 100644
--- a/docker/mods/claude-code/Dockerfile
+++ b/docker/mods/claude-code/Dockerfile
@@ -1,3 +1,25 @@
 # syntax=docker/dockerfile:1
+ARG BUSYBOX_IMAGE=busybox:1.37.0-uclibc
+ARG PASEO_MOD_NAME=claude-code
+ARG PASEO_MOD_PACKAGE=@anthropic-ai/claude-code
+ARG PASEO_MOD_PACKAGE_VERSION=latest
+
+FROM ${BUSYBOX_IMAGE} AS meta
+ARG PASEO_MOD_NAME
+ARG PASEO_MOD_PACKAGE
+ARG PASEO_MOD_PACKAGE_VERSION
+RUN set -eu; \
+    install -d "/root-layer/etc/paseo-mods/${PASEO_MOD_NAME}"; \
+    printf '%s\n' "${PASEO_MOD_PACKAGE}" > "/root-layer/etc/paseo-mods/${PASEO_MOD_NAME}/package"; \
+    printf '%s\n' "${PASEO_MOD_PACKAGE_VERSION}" > "/root-layer/etc/paseo-mods/${PASEO_MOD_NAME}/package-version"
+
 FROM scratch
+ARG PASEO_MOD_NAME=claude-code
+ARG PASEO_MOD_PACKAGE=@anthropic-ai/claude-code
+ARG PASEO_MOD_PACKAGE_VERSION=latest
+LABEL org.opencontainers.image.title="Paseo Docker Mod: ${PASEO_MOD_NAME}" \
+      org.ovlerfork.paseo.mod.name="${PASEO_MOD_NAME}" \
+      org.ovlerfork.paseo.mod.package="${PASEO_MOD_PACKAGE}" \
+      org.ovlerfork.paseo.mod.package.version="${PASEO_MOD_PACKAGE_VERSION}"
 COPY root-layer/ /
+COPY --from=meta /root-layer/ /
diff --git a/docker/mods/claude-code/root-layer/etc/paseo-mods/claude-code/install b/docker/mods/claude-code/root-layer/etc/paseo-mods/claude-code/install
index 0f2251947..5d0656662 100755
--- a/docker/mods/claude-code/root-layer/etc/paseo-mods/claude-code/install
+++ b/docker/mods/claude-code/root-layer/etc/paseo-mods/claude-code/install
@@ -6,6 +6,15 @@ if command -v claude >/dev/null 2>&1; then
   exit 0
 fi
 
-echo "[mod:claude-code] installing @anthropic-ai/claude-code with pnpm"
-paseo-mod-install node @anthropic-ai/claude-code
+package="@anthropic-ai/claude-code"
+version_file="/etc/paseo-mods/claude-code/package-version"
+if [[ -r "$version_file" ]]; then
+  version="$(tr -d '[:space:]' < "$version_file")"
+  if [[ -n "$version" ]]; then
+    package="${package}@${version}"
+  fi
+fi
+
+echo "[mod:claude-code] installing ${package} with pnpm"
+paseo-mod-install node "$package"
 echo "[mod:claude-code] done ($(command -v claude))"
