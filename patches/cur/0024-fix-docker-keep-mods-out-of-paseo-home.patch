From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Herbrant <cdavide98carnemolla@gmail.com>
Date: Mon, 8 Jun 2026 12:09:43 +0200
Subject: [PATCH] fix(docker): keep mods out of paseo home


diff --git a/docker/base/rootfs/etc/s6-overlay/s6-rc.d/init-paseo/run b/docker/base/rootfs/etc/s6-overlay/s6-rc.d/init-paseo/run
index 74ea10f9..277cb3d8 100755
--- a/docker/base/rootfs/etc/s6-overlay/s6-rc.d/init-paseo/run
+++ b/docker/base/rootfs/etc/s6-overlay/s6-rc.d/init-paseo/run
@@ -62,6 +62,18 @@ ensure_owned_dir() {
   chmod "$mode" "$dir" || true
 }
 
+ensure_owned_parent_dir() {
+  local dir="$1"
+  if [[ -z "$dir" ]]; then
+    return 0
+  fi
+  local parent
+  parent="$(dirname "$dir")"
+  if [[ "$parent" == "$CONTAINER_HOME" || "$parent" == "$CONTAINER_HOME"/* ]]; then
+    ensure_owned_dir "$parent" 700
+  fi
+}
+
 # Only chown directory entries, not their contents; avoid clobbering large
 # bind-mounted homes while still making the expected roots writable.
 ensure_owned_dir "$CONTAINER_HOME" 700
@@ -69,7 +81,9 @@ ensure_owned_dir "$PASEO_HOME" 700
 ensure_owned_dir "$CLAUDE_CONFIG_DIR" 700
 ensure_owned_dir "$CODEX_HOME" 700
 ensure_owned_dir "$XDG_CONFIG_HOME" 700
+ensure_owned_parent_dir "$XDG_DATA_HOME"
 ensure_owned_dir "$XDG_DATA_HOME" 700
+ensure_owned_parent_dir "$XDG_STATE_HOME"
 ensure_owned_dir "$XDG_STATE_HOME" 700
 ensure_owned_dir "$XDG_CACHE_HOME" 700
 
diff --git a/docker/base/rootfs/usr/local/bin/docker-mods b/docker/base/rootfs/usr/local/bin/docker-mods
index 796f6af7..2d208db9 100755
--- a/docker/base/rootfs/usr/local/bin/docker-mods
+++ b/docker/base/rootfs/usr/local/bin/docker-mods
@@ -145,6 +145,44 @@ apply_mod() {
 run_install_hooks() {
   shopt -s nullglob
   local hook dir
+  local image_default_home="/home/paseo"
+  local image_default_paseo_home="${image_default_home}/.paseo"
+  local user_home="${HOME:-$image_default_home}"
+  local user_paseo_home="${PASEO_HOME:-}"
+  if [[ -z "$user_paseo_home" || ( "$user_home" != "$image_default_home" && "$user_paseo_home" == "$image_default_paseo_home" ) ]]; then
+    user_paseo_home="${user_home}/.paseo"
+  fi
+
+  local user_claude_config_dir user_codex_home user_xdg_config_home user_xdg_data_home user_xdg_state_home user_xdg_cache_home
+  home_scoped_value() {
+    local name="$1"
+    local suffix="$2"
+    local image_default="${image_default_home}${suffix}"
+    local value="${!name:-}"
+    if [[ -z "$value" || ( "$user_home" != "$image_default_home" && "$value" == "$image_default" ) ]]; then
+      printf '%s' "${user_home}${suffix}"
+    else
+      printf '%s' "$value"
+    fi
+  }
+
+  user_claude_config_dir="$(home_scoped_value CLAUDE_CONFIG_DIR "/.claude")"
+  user_codex_home="$(home_scoped_value CODEX_HOME "/.codex")"
+  user_xdg_config_home="$(home_scoped_value XDG_CONFIG_HOME "/.config")"
+  user_xdg_data_home="$(home_scoped_value XDG_DATA_HOME "/.local/share")"
+  user_xdg_state_home="$(home_scoped_value XDG_STATE_HOME "/.local/state")"
+  user_xdg_cache_home="$(home_scoped_value XDG_CACHE_HOME "/.cache")"
+
+  local install_home="/root"
+  mkdir -p \
+    "${install_home}/.claude" \
+    "${install_home}/.codex" \
+    "${install_home}/.config" \
+    "${install_home}/.local/share" \
+    "${install_home}/.local/state" \
+    "${install_home}/.cache" \
+    /tmp/paseo-npm-cache
+
   for hook in /etc/paseo-mods/*/install; do
     dir="$(dirname "$hook")"
     if [[ -f "${dir}/.done" ]]; then
@@ -152,7 +190,25 @@ run_install_hooks() {
     fi
     echo "[mods] running install hook: ${hook}"
     chmod +x "$hook" || true
-    if "$hook"; then
+    if env \
+      HOME="$install_home" \
+      PASEO_HOME="${install_home}/.paseo" \
+      CLAUDE_CONFIG_DIR="${install_home}/.claude" \
+      CODEX_HOME="${install_home}/.codex" \
+      XDG_CONFIG_HOME="${install_home}/.config" \
+      XDG_DATA_HOME="${install_home}/.local/share" \
+      XDG_STATE_HOME="${install_home}/.local/state" \
+      XDG_CACHE_HOME="${install_home}/.cache" \
+      npm_config_cache=/tmp/paseo-npm-cache \
+      PASEO_USER_HOME="$user_home" \
+      PASEO_USER_PASEO_HOME="$user_paseo_home" \
+      PASEO_USER_CLAUDE_CONFIG_DIR="$user_claude_config_dir" \
+      PASEO_USER_CODEX_HOME="$user_codex_home" \
+      PASEO_USER_XDG_CONFIG_HOME="$user_xdg_config_home" \
+      PASEO_USER_XDG_DATA_HOME="$user_xdg_data_home" \
+      PASEO_USER_XDG_STATE_HOME="$user_xdg_state_home" \
+      PASEO_USER_XDG_CACHE_HOME="$user_xdg_cache_home" \
+      bash "$hook"; then
       touch "${dir}/.done"
     else
       echo "[mods] WARNING: install hook failed: ${hook}" >&2
diff --git a/docker/base/scripts/install-paseo.sh b/docker/base/scripts/install-paseo.sh
index c45d29c0..ed1d628f 100755
--- a/docker/base/scripts/install-paseo.sh
+++ b/docker/base/scripts/install-paseo.sh
@@ -16,19 +16,32 @@ if [ "$ALPINE" -eq 1 ]; then
   apk add --no-cache --virtual .paseo-build-deps build-base python3
 fi
 
+INSTALL_HOME=/root
+NPM_CACHE=/tmp/paseo-npm-cache
+mkdir -p "$INSTALL_HOME" "$NPM_CACHE"
+
 # sherpa-onnx (voice) is optional and has no musl build; skip it everywhere.
 ONNXRUNTIME_NODE_INSTALL=skip \
+  HOME="$INSTALL_HOME" \
+  npm_config_cache="$NPM_CACHE" \
   npm install -g --omit=optional \
     "@getpaseo/server@${PASEO_VERSION}" \
     "@getpaseo/cli@${PASEO_VERSION}"
 
 # Record the absolute path to the supervisor entrypoint so the launcher can
 # exec it directly (the @getpaseo/server package exposes no bin).
-SERVER_ENTRY="$(npm root -g)/@getpaseo/server/dist/scripts/supervisor-entrypoint.js"
+SERVER_ENTRY="$(
+  HOME="$INSTALL_HOME" \
+    npm_config_cache="$NPM_CACHE" \
+    npm root -g
+)/@getpaseo/server/dist/scripts/supervisor-entrypoint.js"
 test -f "$SERVER_ENTRY"
 printf '%s\n' "$SERVER_ENTRY" > /etc/paseo-server-entry
 
-npm cache clean --force >/dev/null 2>&1 || true
+HOME="$INSTALL_HOME" \
+  npm_config_cache="$NPM_CACHE" \
+  npm cache clean --force >/dev/null 2>&1 || true
+rm -rf "$NPM_CACHE"
 
 if [ "$ALPINE" -eq 1 ]; then
   apk del .paseo-build-deps
diff --git a/docker/mods/opencode/root-layer/etc/paseo-mods/opencode/install b/docker/mods/opencode/root-layer/etc/paseo-mods/opencode/install
index 4dd16b05..69b34690 100755
--- a/docker/mods/opencode/root-layer/etc/paseo-mods/opencode/install
+++ b/docker/mods/opencode/root-layer/etc/paseo-mods/opencode/install
@@ -2,11 +2,11 @@
 # Install OpenCode so Paseo exposes the `opencode` provider.
 set -euo pipefail
 
-PASEO_HOME="${PASEO_HOME:-/home/paseo}"
-XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$PASEO_HOME/.config}"
-XDG_DATA_HOME="${XDG_DATA_HOME:-$PASEO_HOME/.local/share}"
-XDG_STATE_HOME="${XDG_STATE_HOME:-$PASEO_HOME/.local/state}"
-XDG_CACHE_HOME="${XDG_CACHE_HOME:-$PASEO_HOME/.cache}"
+PASEO_USER_HOME="${PASEO_USER_HOME:-/home/paseo}"
+PASEO_USER_XDG_CONFIG_HOME="${PASEO_USER_XDG_CONFIG_HOME:-$PASEO_USER_HOME/.config}"
+PASEO_USER_XDG_DATA_HOME="${PASEO_USER_XDG_DATA_HOME:-$PASEO_USER_HOME/.local/share}"
+PASEO_USER_XDG_STATE_HOME="${PASEO_USER_XDG_STATE_HOME:-$PASEO_USER_HOME/.local/state}"
+PASEO_USER_XDG_CACHE_HOME="${PASEO_USER_XDG_CACHE_HOME:-$PASEO_USER_HOME/.cache}"
 
 ensure_opencode_dir() {
   local dir="$1"
@@ -24,19 +24,19 @@ repair_opencode_tree() {
   chmod 700 "$dir" || true
 }
 
-ensure_opencode_dir "$XDG_CONFIG_HOME/opencode"
-ensure_opencode_dir "$XDG_DATA_HOME/opencode"
-ensure_opencode_dir "$XDG_DATA_HOME/opencode/log"
-ensure_opencode_dir "$XDG_DATA_HOME/opencode/project"
-ensure_opencode_dir "$XDG_DATA_HOME/opencode/bin"
-ensure_opencode_dir "$XDG_STATE_HOME/opencode"
-ensure_opencode_dir "$XDG_CACHE_HOME/opencode"
-ensure_opencode_dir "$XDG_CACHE_HOME/opencode/bin"
+ensure_opencode_dir "$PASEO_USER_XDG_CONFIG_HOME/opencode"
+ensure_opencode_dir "$PASEO_USER_XDG_DATA_HOME/opencode"
+ensure_opencode_dir "$PASEO_USER_XDG_DATA_HOME/opencode/log"
+ensure_opencode_dir "$PASEO_USER_XDG_DATA_HOME/opencode/project"
+ensure_opencode_dir "$PASEO_USER_XDG_DATA_HOME/opencode/bin"
+ensure_opencode_dir "$PASEO_USER_XDG_STATE_HOME/opencode"
+ensure_opencode_dir "$PASEO_USER_XDG_CACHE_HOME/opencode"
+ensure_opencode_dir "$PASEO_USER_XDG_CACHE_HOME/opencode/bin"
 
-repair_opencode_tree "$XDG_CONFIG_HOME/opencode"
-repair_opencode_tree "$XDG_DATA_HOME/opencode"
-repair_opencode_tree "$XDG_STATE_HOME/opencode"
-repair_opencode_tree "$XDG_CACHE_HOME/opencode"
+repair_opencode_tree "$PASEO_USER_XDG_CONFIG_HOME/opencode"
+repair_opencode_tree "$PASEO_USER_XDG_DATA_HOME/opencode"
+repair_opencode_tree "$PASEO_USER_XDG_STATE_HOME/opencode"
+repair_opencode_tree "$PASEO_USER_XDG_CACHE_HOME/opencode"
 
 if command -v opencode >/dev/null 2>&1; then
   echo "[mod:opencode] opencode already on PATH — skipping install."
diff --git a/docs/docker.md b/docs/docker.md
index e11522bf..5099f4fe 100644
--- a/docs/docker.md
+++ b/docs/docker.md
@@ -140,6 +140,14 @@ with `-e PI_NPM_PACKAGE=...` if it ever changes upstream.
 Mod installs run on every fresh `docker run`; the hook skips reinstalling if the
 binary is already present (e.g. after `docker restart`).
 
+Install hooks run as root because they install system-wide agent CLIs, but the
+mods loader gives them a root-scoped install environment (`HOME`, XDG dirs,
+`CODEX_HOME`, `CLAUDE_CONFIG_DIR`, and the npm cache point under `/root` or
+`/tmp`). This prevents `npm install -g` package scripts from creating root-owned
+files in `/home/paseo`. Hooks that intentionally need the runtime user's paths
+should read the `PASEO_USER_*` variables exposed by the loader instead of
+`HOME`.
+
 ### Agent credentials
 
 Each agent manages its own auth and stores it under `HOME` (`/home/paseo` by
