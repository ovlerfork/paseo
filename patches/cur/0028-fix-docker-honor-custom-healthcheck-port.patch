From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Herbrant <cdavide98carnemolla@gmail.com>
Date: Tue, 9 Jun 2026 11:31:13 +0200
Subject: [PATCH] fix(docker): honor custom healthcheck port


diff --git a/docker/base/Dockerfile b/docker/base/Dockerfile
index 21837922..7d42ce34 100644
--- a/docker/base/Dockerfile
+++ b/docker/base/Dockerfile
@@ -93,6 +93,6 @@ EXPOSE 6767
 VOLUME /home/paseo
 
 HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
-  CMD node -e "require('net').connect(6767,'127.0.0.1').on('connect',function(){process.exit(0)}).on('error',function(){process.exit(1)})" || exit 1
+  CMD node -e "const listen=process.env.PASEO_LISTEN||'0.0.0.0:6767'; const match=listen.match(/:(\d+)$/); const port=match?Number(match[1]):6767; require('net').connect(port,'127.0.0.1').on('connect',function(){process.exit(0)}).on('error',function(){process.exit(1)})" || exit 1
 
 ENTRYPOINT ["/init"]
diff --git a/docker/base/rootfs/etc/s6-overlay/s6-rc.d/svc-paseo-pair/run b/docker/base/rootfs/etc/s6-overlay/s6-rc.d/svc-paseo-pair/run
index c79b22c6..e329297d 100755
--- a/docker/base/rootfs/etc/s6-overlay/s6-rc.d/svc-paseo-pair/run
+++ b/docker/base/rootfs/etc/s6-overlay/s6-rc.d/svc-paseo-pair/run
@@ -22,6 +22,12 @@ esac
 
 PORT="${PASEO_LISTEN##*:}"
 : "${PORT:=6767}"
+case "$PORT" in
+  *[!0-9]*)
+    echo "[pair] invalid PASEO_LISTEN port '${PORT}'; using 6767 for readiness probe." >&2
+    PORT=6767
+    ;;
+esac
 
 # Wait for the daemon to accept connections (s6 marks the longrun "up" before it
 # actually listens). Reuse the same net.connect probe as the HEALTHCHECK.
