From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Herbrant <cdavide98carnemolla@gmail.com>
Date: Wed, 3 Jun 2026 23:50:55 +0200
Subject: [PATCH] fix(docker): create agent config dirs


diff --git a/docker/base/rootfs/etc/s6-overlay/s6-rc.d/init-paseo/run b/docker/base/rootfs/etc/s6-overlay/s6-rc.d/init-paseo/run
index 136640e1..a966fdeb 100755
--- a/docker/base/rootfs/etc/s6-overlay/s6-rc.d/init-paseo/run
+++ b/docker/base/rootfs/etc/s6-overlay/s6-rc.d/init-paseo/run
@@ -28,9 +28,37 @@ esac
 
 PASEO_HOME="${PASEO_HOME:-/config}"
 mkdir -p "$PASEO_HOME"
-# Only chown the top level + paseo-owned subdirs; avoid clobbering a large
-# bind-mounted /config on every boot.
-chown paseo:paseo "$PASEO_HOME" || true
-chmod 700 "$PASEO_HOME" || true
+
+ensure_paseo_dir() {
+  local dir="$1"
+  local mode="${2:-700}"
+  local existed=0
+  if [[ -z "$dir" ]]; then
+    return 0
+  fi
+  [[ -d "$dir" ]] && existed=1
+  mkdir -p "$dir"
+  case "$dir" in
+    "$PASEO_HOME" | "$PASEO_HOME"/*)
+      chown paseo:paseo "$dir" || true
+      chmod "$mode" "$dir" || true
+      ;;
+    *)
+      if [[ "$existed" == 0 ]]; then
+        chown paseo:paseo "$dir" || true
+        chmod "$mode" "$dir" || true
+      fi
+      ;;
+  esac
+}
+
+# Only chown the top level + small paseo-owned config dirs; avoid clobbering a
+# large bind-mounted /config on every boot.
+ensure_paseo_dir "$PASEO_HOME" 700
+ensure_paseo_dir "${CLAUDE_CONFIG_DIR:-${PASEO_HOME}/.claude}" 700
+ensure_paseo_dir "${CODEX_HOME:-${PASEO_HOME}/.codex}" 700
+ensure_paseo_dir "${XDG_CONFIG_HOME:-${PASEO_HOME}/.config}" 700
+ensure_paseo_dir "${XDG_DATA_HOME:-${PASEO_HOME}/.local/share}" 700
+ensure_paseo_dir "${XDG_CACHE_HOME:-${PASEO_HOME}/.cache}" 700
 
 echo "[init] /config ready (PUID=${PUID} PGID=${PGID} home=${PASEO_HOME})"
diff --git a/docs/docker.md b/docs/docker.md
index 8c2d2a17..6b612375 100644
--- a/docs/docker.md
+++ b/docs/docker.md
@@ -78,6 +78,11 @@ A `docker compose` deployment is in
 | `/config`    | `PASEO_HOME` — `config.json`, `agents/`, `projects/`, `loops/`, logs, **and** agent credentials (`~/.claude`, `~/.codex`, ...). `HOME` is set to `/config`, so everything an agent writes to its home dir persists here. |
 | `/workspace` | The code Paseo operates on. Bind-mount one or more of your repos.                                                                                                                                                        |
 
+On boot, the image creates the small agent config directories under `/config`
+(`.claude`, `.codex`, `.config`, `.local/share`, `.cache`) and assigns them to
+the `paseo` user. Codex expects `CODEX_HOME` to exist before launch, so an empty
+fresh `/config` volume is still valid.
+
 Set `PUID`/`PGID` to the uid/gid that owns the bind-mounted folders on the host
 (`id -u` / `id -g`) so the daemon and agents can read and write your files.
 
