-  usermod -o -u "$PUID" paseo || true
+case "$PASEO_RUNTIME_USER" in
+  paseo | root) ;;
+  *)
+    echo "[init] Unsupported PASEO_RUNTIME_USER=${PASEO_RUNTIME_USER}; expected paseo or root." >&2
+    exit 1
+    ;;
+esac
+
+if [[ "$PASEO_RUNTIME_USER" == "paseo" ]]; then
+  if [[ "$(id -g paseo)" != "$PGID" ]]; then
+    groupmod -o -g "$PGID" paseo || true
+  fi
+  if [[ "$(id -u paseo)" != "$PUID" ]]; then
+    usermod -o -u "$PUID" paseo || true
+  fi
 fi
 
 SUDOERS_FILE="/etc/sudoers.d/paseo-enable-sudo"
 case "$(printf '%s' "${PASEO_ENABLE_SUDO:-}" | tr '[:upper:]' '[:lower:]')" in
   true)
     mkdir -p /etc/sudoers.d
-    printf 'paseo ALL=(ALL) NOPASSWD:ALL\n' > "$SUDOERS_FILE"
-    chmod 0440 "$SUDOERS_FILE"
-    echo "[init] PASEO_ENABLE_SUDO enabled: passwordless sudo granted to paseo."
+    if [[ "$PASEO_RUNTIME_USER" == "paseo" ]]; then
+      printf 'paseo ALL=(ALL) NOPASSWD:ALL\n' > "$SUDOERS_FILE"
+      chmod 0440 "$SUDOERS_FILE"
+      echo "[init] PASEO_ENABLE_SUDO enabled: passwordless sudo granted to paseo."
+    else
+      rm -f "$SUDOERS_FILE"
+      echo "[init] PASEO_ENABLE_SUDO ignored: runtime already runs as root."
+    fi
     ;;
   *)
     rm -f "$SUDOERS_FILE"
