 #!/command/with-contenv bash
-# Seed PASEO_HOME and align the paseo user with the host volume owner.
+# Seed PASEO_HOME and align the runtime home with the selected container user.
 set -euo pipefail
 
+PASEO_RUNTIME_USER="${PASEO_RUNTIME_USER:-paseo}"
 PUID="${PUID:-911}"
 PGID="${PGID:-911}"
 
-if [[ "$(id -g paseo)" != "$PGID" ]]; then
-  groupmod -o -g "$PGID" paseo || true
-fi
