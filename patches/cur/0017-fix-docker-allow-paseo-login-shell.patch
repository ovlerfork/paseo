From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Herbrant <cdavide98carnemolla@gmail.com>
Date: Fri, 5 Jun 2026 12:39:56 +0200
Subject: [PATCH] fix(docker): allow paseo login shell


diff --git a/docker/base/Dockerfile b/docker/base/Dockerfile
index 5cbd2a07..8cb35a99 100644
--- a/docker/base/Dockerfile
+++ b/docker/base/Dockerfile
@@ -62,10 +62,10 @@ RUN PASEO_VERSION="${PASEO_VERSION}" /tmp/install-paseo.sh && rm -f /tmp/install
 RUN set -eux; \
     if [ -f /etc/alpine-release ]; then \
       addgroup -g 911 paseo; \
-      adduser -D -H -h /home/paseo -u 911 -G paseo -s /sbin/nologin paseo; \
+      adduser -D -H -h /home/paseo -u 911 -G paseo -s /bin/bash paseo; \
     else \
       groupadd -g 911 paseo; \
-      useradd -u 911 -g paseo -d /home/paseo -M -s /usr/sbin/nologin paseo; \
+      useradd -u 911 -g paseo -d /home/paseo -M -s /bin/bash paseo; \
     fi
 
 # s6 service definitions, the docker-mods loader and the daemon launcher.
diff --git a/docker/base/rootfs/etc/s6-overlay/s6-rc.d/init-paseo/run b/docker/base/rootfs/etc/s6-overlay/s6-rc.d/init-paseo/run
index 553ede1d..d3062988 100755
--- a/docker/base/rootfs/etc/s6-overlay/s6-rc.d/init-paseo/run
+++ b/docker/base/rootfs/etc/s6-overlay/s6-rc.d/init-paseo/run
@@ -29,6 +29,7 @@ esac
 DEFAULT_PASEO_HOME="/home/paseo"
 PASEO_HOME="${PASEO_HOME:-$DEFAULT_PASEO_HOME}"
 mkdir -p "$PASEO_HOME"
+usermod -d "$PASEO_HOME" paseo || true
 
 home_scoped_dir() {
   local name="$1"
diff --git a/docs/docker.md b/docs/docker.md
index 05aa3f29..3530bbd7 100644
--- a/docs/docker.md
+++ b/docs/docker.md
@@ -159,6 +159,10 @@ docker exec -it --user paseo paseo claude
 docker exec -it --user paseo paseo codex
 ```
 
+The image gives the unprivileged `paseo` user a real login shell. From a root
+shell inside the container, `su -l paseo` drops into the same persistent home
+used by the daemon, including custom `PASEO_HOME` paths.
+
 This first-run login step is not needed for providers configured entirely with
 API key environment variables passed to the container, such as
 `ANTHROPIC_API_KEY` or `OPENAI_API_KEY`; those env vars are inherited by the
