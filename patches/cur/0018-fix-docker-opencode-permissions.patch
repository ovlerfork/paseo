From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Herbrant <cdavide98carnemolla@gmail.com>
Date: Fri, 5 Jun 2026 13:37:27 +0200
Subject: [PATCH] fix docker opencode permissions


diff --git a/docker/base/Dockerfile b/docker/base/Dockerfile
index 8cb35a99..ccef4582 100644
--- a/docker/base/Dockerfile
+++ b/docker/base/Dockerfile
@@ -25,6 +25,7 @@ ENV PASEO_HOME=/home/paseo \
     CODEX_HOME=/home/paseo/.codex \
     XDG_CONFIG_HOME=/home/paseo/.config \
     XDG_DATA_HOME=/home/paseo/.local/share \
+    XDG_STATE_HOME=/home/paseo/.local/state \
     XDG_CACHE_HOME=/home/paseo/.cache \
     ONNXRUNTIME_NODE_INSTALL=skip \
     PUID=911 \
@@ -66,7 +67,9 @@ RUN set -eux; \
     else \
       groupadd -g 911 paseo; \
       useradd -u 911 -g paseo -d /home/paseo -M -s /bin/bash paseo; \
-    fi
+    fi; \
+    paseo_shell="$(awk -F: '$1 == "paseo" { print $7 }' /etc/passwd)"; \
+    [ "$paseo_shell" = "/bin/bash" ]
 
 # s6 service definitions, the docker-mods loader and the daemon launcher.
 COPY rootfs/ /
diff --git a/docker/base/rootfs/etc/s6-overlay/s6-rc.d/init-paseo/run b/docker/base/rootfs/etc/s6-overlay/s6-rc.d/init-paseo/run
index d3062988..af8b0163 100755
--- a/docker/base/rootfs/etc/s6-overlay/s6-rc.d/init-paseo/run
+++ b/docker/base/rootfs/etc/s6-overlay/s6-rc.d/init-paseo/run
@@ -45,6 +45,7 @@ home_scoped_dir CLAUDE_CONFIG_DIR "/.claude"
 home_scoped_dir CODEX_HOME "/.codex"
 home_scoped_dir XDG_CONFIG_HOME "/.config"
 home_scoped_dir XDG_DATA_HOME "/.local/share"
+home_scoped_dir XDG_STATE_HOME "/.local/state"
 home_scoped_dir XDG_CACHE_HOME "/.cache"
 
 ensure_paseo_dir() {
@@ -77,6 +78,7 @@ ensure_paseo_dir "$CLAUDE_CONFIG_DIR" 700
 ensure_paseo_dir "$CODEX_HOME" 700
 ensure_paseo_dir "$XDG_CONFIG_HOME" 700
 ensure_paseo_dir "$XDG_DATA_HOME" 700
+ensure_paseo_dir "$XDG_STATE_HOME" 700
 ensure_paseo_dir "$XDG_CACHE_HOME" 700
 
 echo "[init] PASEO_HOME ready (PUID=${PUID} PGID=${PGID} home=${PASEO_HOME})"
diff --git a/docker/mods/opencode/root-layer/etc/paseo-mods/opencode/install b/docker/mods/opencode/root-layer/etc/paseo-mods/opencode/install
index 34321521..4dd16b05 100755
--- a/docker/mods/opencode/root-layer/etc/paseo-mods/opencode/install
+++ b/docker/mods/opencode/root-layer/etc/paseo-mods/opencode/install
@@ -5,6 +5,7 @@ set -euo pipefail
 PASEO_HOME="${PASEO_HOME:-/home/paseo}"
 XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$PASEO_HOME/.config}"
 XDG_DATA_HOME="${XDG_DATA_HOME:-$PASEO_HOME/.local/share}"
+XDG_STATE_HOME="${XDG_STATE_HOME:-$PASEO_HOME/.local/state}"
 XDG_CACHE_HOME="${XDG_CACHE_HOME:-$PASEO_HOME/.cache}"
 
 ensure_opencode_dir() {
@@ -14,14 +15,29 @@ ensure_opencode_dir() {
   chmod 700 "$dir" || true
 }
 
+repair_opencode_tree() {
+  local dir="$1"
+  if [[ ! -d "$dir" ]]; then
+    return 0
+  fi
+  chown -R paseo:paseo "$dir" || true
+  chmod 700 "$dir" || true
+}
+
 ensure_opencode_dir "$XDG_CONFIG_HOME/opencode"
 ensure_opencode_dir "$XDG_DATA_HOME/opencode"
 ensure_opencode_dir "$XDG_DATA_HOME/opencode/log"
 ensure_opencode_dir "$XDG_DATA_HOME/opencode/project"
 ensure_opencode_dir "$XDG_DATA_HOME/opencode/bin"
+ensure_opencode_dir "$XDG_STATE_HOME/opencode"
 ensure_opencode_dir "$XDG_CACHE_HOME/opencode"
 ensure_opencode_dir "$XDG_CACHE_HOME/opencode/bin"
 
+repair_opencode_tree "$XDG_CONFIG_HOME/opencode"
+repair_opencode_tree "$XDG_DATA_HOME/opencode"
+repair_opencode_tree "$XDG_STATE_HOME/opencode"
+repair_opencode_tree "$XDG_CACHE_HOME/opencode"
+
 if command -v opencode >/dev/null 2>&1; then
   echo "[mod:opencode] opencode already on PATH — skipping install."
   exit 0
diff --git a/docs/docker.md b/docs/docker.md
index 3530bbd7..7ab97535 100644
--- a/docs/docker.md
+++ b/docs/docker.md
@@ -85,9 +85,9 @@ A `docker compose` deployment is in
 | `/workspace`  | The code Paseo operates on. Bind-mount one or more of your repos.                                                                                                                                                                      |
 
 On boot, the image creates the small agent config directories under
-`PASEO_HOME` (`.claude`, `.codex`, `.config`, `.local/share`, `.cache`) and
-assigns them to the `paseo` user. Codex expects `CODEX_HOME` to exist before
-launch, so an empty fresh `/home/paseo` volume is still valid.
+`PASEO_HOME` (`.claude`, `.codex`, `.config`, `.local/share`, `.local/state`,
+`.cache`) and assigns them to the `paseo` user. Codex expects `CODEX_HOME` to
+exist before launch, so an empty fresh `/home/paseo` volume is still valid.
 
 To use a different persistent home, set `PASEO_HOME` and mount the same
 container path. For example, to store daemon state in a dedicated Docker volume:
@@ -271,11 +271,14 @@ Ubuntu 22.04 arm64.
   stop the daemon. On Alpine, native agents (Codex) will not install.
 - **Can't connect / 403** — set `PASEO_HOSTNAMES` if reaching the daemon by a DNS
   name; IPs and `localhost` are allowed by default.
-- **OpenCode says `unable to open database file` on first run** — check that
-  the OpenCode mod ran and that `/home/paseo/.local/share/opencode` and its
-  `log` directory are owned by the container's `paseo` user. If `/home/paseo` is
-  bind-mounted, set `PUID`/`PGID` to match the host owner of that mounted
-  folder.
+- **OpenCode says `unable to open database file` or fails on
+  `PRAGMA wal_checkpoint(PASSIVE)`** — check that the OpenCode mod ran and that
+  `/home/paseo/.local/share/opencode` and its `log` directory are owned by the
+  container's `paseo` user. If `/home/paseo` is bind-mounted, set `PUID`/`PGID`
+  to match the host owner of that mounted folder. Running `opencode` with
+  `sudo` can leave root-owned OpenCode database, WAL, SHM, or log files in the
+  persistent home; the OpenCode mod repairs ownership for its config, data, and
+  state/cache directories on the next container start.
 - **Permission errors on your repo** — set `PUID`/`PGID` to match the host owner
   of the bind mount.
 - **Daemon logs** — `docker exec paseo tail -f /home/paseo/daemon.log`.
