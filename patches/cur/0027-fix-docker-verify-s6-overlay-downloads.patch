From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Herbrant <cdavide98carnemolla@gmail.com>
Date: Tue, 9 Jun 2026 10:06:37 +0200
Subject: [PATCH] fix(docker): verify s6 overlay downloads


diff --git a/.github/workflows/docker.yml b/.github/workflows/docker.yml
index 15834f5e..6cfff75f 100644
--- a/.github/workflows/docker.yml
+++ b/.github/workflows/docker.yml
@@ -92,14 +92,18 @@ jobs:
         id: tags
         env:
           IMAGE_BASE: ghcr.io/${{ needs.setup.outputs.owner }}/paseo
+          RESOLVED_VERSION: ${{ needs.setup.outputs.version }}
+          MATRIX_NAME: ${{ matrix.name }}
+          MATRIX_MOVING: ${{ matrix.moving }}
+          MATRIX_LATEST: ${{ matrix.latest }}
         run: |
           set -euo pipefail
-          V="${{ needs.setup.outputs.version }}"
-          tags="${IMAGE_BASE}:${V}-${{ matrix.name }}"
-          if [[ -n "${{ matrix.moving }}" ]]; then
-            tags="${tags}"$'\n'"${IMAGE_BASE}:${{ matrix.moving }}"
+          V="${RESOLVED_VERSION}"
+          tags="${IMAGE_BASE}:${V}-${MATRIX_NAME}"
+          if [[ -n "${MATRIX_MOVING}" ]]; then
+            tags="${tags}"$'\n'"${IMAGE_BASE}:${MATRIX_MOVING}"
           fi
-          if [[ "${{ matrix.latest }}" == "true" ]]; then
+          if [[ "${MATRIX_LATEST}" == "true" ]]; then
             tags="${tags}"$'\n'"${IMAGE_BASE}:latest"
           fi
           {
@@ -140,6 +144,9 @@ jobs:
         if: matrix.name == 'arch'
         env:
           TAGS: ${{ steps.tags.outputs.tags }}
+          ARCH_BASE_IMAGE: ${{ matrix.base }}
+          RESOLVED_VERSION: ${{ needs.setup.outputs.version }}
+          SHOULD_PUSH: ${{ needs.setup.outputs.push }}
         run: |
           set -euo pipefail
           mapfile -t tags <<< "${TAGS}"
@@ -153,11 +160,11 @@ jobs:
           docker build \
             --platform linux/amd64 \
             "${tag_args[@]}" \
-            --build-arg BASE_IMAGE=${{ matrix.base }} \
-            --build-arg PASEO_VERSION=${{ needs.setup.outputs.version }} \
+            --build-arg "BASE_IMAGE=${ARCH_BASE_IMAGE}" \
+            --build-arg "PASEO_VERSION=${RESOLVED_VERSION}" \
             docker/base
 
-          if [[ "${{ needs.setup.outputs.push }}" == "true" ]]; then
+          if [[ "${SHOULD_PUSH}" == "true" ]]; then
             for tag in "${tags[@]}"; do
               if [[ -n "${tag}" ]]; then
                 docker push "${tag}"
diff --git a/docker/base/Dockerfile b/docker/base/Dockerfile
index 0e5bf724..21837922 100644
--- a/docker/base/Dockerfile
+++ b/docker/base/Dockerfile
@@ -46,13 +46,19 @@ RUN set -eux; \
       *) echo "Unsupported TARGETARCH: ${TARGETARCH}" >&2; exit 1 ;; \
     esac; \
     cd /tmp; \
-    curl -fsSL -o s6-noarch.tar.xz \
+    curl -fsSL -O \
       "https://github.com/just-containers/s6-overlay/releases/download/v${S6_OVERLAY_VERSION}/s6-overlay-noarch.tar.xz"; \
-    curl -fsSL -o s6-arch.tar.xz \
+    curl -fsSL -O \
+      "https://github.com/just-containers/s6-overlay/releases/download/v${S6_OVERLAY_VERSION}/s6-overlay-noarch.tar.xz.sha256"; \
+    curl -fsSL -O \
       "https://github.com/just-containers/s6-overlay/releases/download/v${S6_OVERLAY_VERSION}/s6-overlay-${S6_ARCH}.tar.xz"; \
-    tar -C / -Jxpf s6-noarch.tar.xz; \
-    tar -C / -Jxpf s6-arch.tar.xz; \
-    rm -f s6-noarch.tar.xz s6-arch.tar.xz
+    curl -fsSL -O \
+      "https://github.com/just-containers/s6-overlay/releases/download/v${S6_OVERLAY_VERSION}/s6-overlay-${S6_ARCH}.tar.xz.sha256"; \
+    sha256sum -c s6-overlay-noarch.tar.xz.sha256; \
+    sha256sum -c "s6-overlay-${S6_ARCH}.tar.xz.sha256"; \
+    tar -C / -Jxpf s6-overlay-noarch.tar.xz; \
+    tar -C / -Jxpf "s6-overlay-${S6_ARCH}.tar.xz"; \
+    rm -f s6-overlay-noarch.tar.xz s6-overlay-noarch.tar.xz.sha256 "s6-overlay-${S6_ARCH}.tar.xz" "s6-overlay-${S6_ARCH}.tar.xz.sha256"
 
 # Paseo server + CLI from npm. On Alpine this compiles node-pty against musl
 # using a throwaway toolchain that the script removes afterwards.
