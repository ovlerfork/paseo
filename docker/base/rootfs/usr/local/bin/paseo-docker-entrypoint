#!/usr/bin/env bash
set -euo pipefail

IMAGE_HOME="/home/paseo"
PASEO_RUNTIME_USER="${PASEO_RUNTIME_USER:-paseo}"

case "$PASEO_RUNTIME_USER" in
  paseo | root) ;;
  *)
    echo "[paseo] FATAL: unsupported PASEO_RUNTIME_USER=${PASEO_RUNTIME_USER}; expected paseo or root." >&2
    exit 1
    ;;
esac

if [[ "$PASEO_RUNTIME_USER" == "root" && "${HOME:-$IMAGE_HOME}" == "$IMAGE_HOME" ]]; then
  HOME="/root"
else
  : "${HOME:=$IMAGE_HOME}"
fi

home_default() {
  local name="$1"
  local suffix="$2"
  local current="${!name:-}"
  local image_default="${IMAGE_HOME}${suffix}"
  if [[ -z "$current" || ( "$PASEO_RUNTIME_USER" == "root" && "$current" == "$image_default" ) ]]; then
    printf -v "$name" '%s' "${HOME}${suffix}"
  fi
}

home_default PASEO_HOME "/.paseo"
: "${PASEO_LISTEN:=0.0.0.0:6767}"
: "${PASEO_WEB_UI_ENABLED:=true}"
: "${PASEO_LOG_LEVEL:=info}"
: "${PASEO_LOG_FORMAT:=json}"
: "${PASEO_SSH_AUTHORIZED_KEYS_FILE:=/run/configs/paseo_ssh_authorized_keys}"
: "${PASEO_SSH_PORT:=2222}"
home_default CLAUDE_CONFIG_DIR "/.claude"
home_default CODEX_HOME "/.codex"
home_default XDG_CONFIG_HOME "/.config"
home_default XDG_DATA_HOME "/.local/share"
home_default XDG_STATE_HOME "/.local/state"
home_default XDG_CACHE_HOME "/.cache"

export HOME
export PASEO_RUNTIME_USER
export PASEO_HOME
export PASEO_LISTEN
export PASEO_WEB_UI_ENABLED
export PASEO_LOG_LEVEL
export PASEO_LOG_FORMAT
export PASEO_SSH_AUTHORIZED_KEYS_FILE
export PASEO_SSH_PORT
export CLAUDE_CONFIG_DIR
export CODEX_HOME
export XDG_CONFIG_HOME
export XDG_DATA_HOME
export XDG_STATE_HOME
export XDG_CACHE_HOME

ensure_dir() {
  local dir="$1"
  mkdir -p "$dir"
  if [[ "$(id -u)" == "0" && "$PASEO_RUNTIME_USER" == "paseo" ]]; then
    local owner
    owner="$(stat -c "%u" "$dir")"
    if [[ "$owner" == "0" ]]; then
      chown paseo:paseo "$dir"
    fi
  fi
}

ensure_dir "$HOME"
ensure_dir "$PASEO_HOME"
ensure_dir "$CLAUDE_CONFIG_DIR"
ensure_dir "$CODEX_HOME"
ensure_dir "$XDG_CONFIG_HOME"
ensure_dir "$XDG_DATA_HOME"
ensure_dir "$XDG_STATE_HOME"
ensure_dir "$XDG_CACHE_HOME"

apply_docker_mods() {
  if [[ -z "${DOCKER_MODS:-}" || -z "${DOCKER_MODS// }" ]]; then
    echo "[mods] DOCKER_MODS not set; no agent mods to apply."
    return
  fi
  if [[ "$(id -u)" != "0" ]]; then
    echo "[paseo] FATAL: DOCKER_MODS requires the container entrypoint to run as root." >&2
    exit 1
  fi
  /usr/local/bin/docker-mods
}

start_sshd() {
  case "${PASEO_SSH_ENABLED:-false}" in
    true | 1 | yes) ;;
    false | 0 | no | "")
      return
      ;;
    *)
      echo "[paseo] FATAL: unsupported PASEO_SSH_ENABLED=${PASEO_SSH_ENABLED}; expected true or false." >&2
      exit 1
      ;;
  esac

  if [[ "$(id -u)" != "0" ]]; then
    echo "[paseo] FATAL: PASEO_SSH_ENABLED requires the container entrypoint to run as root." >&2
    exit 1
  fi
  if [[ ! -s "$PASEO_SSH_AUTHORIZED_KEYS_FILE" ]]; then
    echo "[paseo] FATAL: PASEO_SSH_AUTHORIZED_KEYS_FILE is missing or empty: ${PASEO_SSH_AUTHORIZED_KEYS_FILE}" >&2
    exit 1
  fi

  local ssh_dir="$HOME/.ssh"
  install -d -m 700 "$ssh_dir"
  install -m 600 "$PASEO_SSH_AUTHORIZED_KEYS_FILE" "$ssh_dir/authorized_keys"
  if [[ "$PASEO_RUNTIME_USER" == "paseo" ]]; then
    chown -R paseo:paseo "$ssh_dir"
  fi
  install -d -m 755 /run/sshd
  ssh-keygen -A

  echo "[paseo] starting sshd on port ${PASEO_SSH_PORT} for ${PASEO_RUNTIME_USER}"
  /usr/sbin/sshd \
    -o AuthorizedKeysFile=.ssh/authorized_keys \
    -o KbdInteractiveAuthentication=no \
    -o PasswordAuthentication=no \
    -o PermitRootLogin=prohibit-password \
    -o PubkeyAuthentication=yes \
    -p "$PASEO_SSH_PORT"
}

apply_docker_mods
start_sshd

if [[ "$#" -gt 0 ]]; then
  if [[ "$(id -u)" == "0" && "$PASEO_RUNTIME_USER" == "paseo" ]]; then
    exec gosu paseo "$@"
  fi
  exec "$@"
fi

if [[ -z "${PASEO_PASSWORD:-}" ]]; then
  {
    echo "[paseo] WARNING: PASEO_PASSWORD is not set."
    echo "[paseo] The daemon accepts unauthenticated control connections from any client that can reach it."
    echo "[paseo] Set PASEO_PASSWORD for any published port or network-reachable deployment."
  } >&2
fi

if [[ ! -f /etc/paseo-server-entry ]]; then
  echo "[paseo] FATAL: /etc/paseo-server-entry is missing." >&2
  exit 1
fi

entry="$(cat /etc/paseo-server-entry)"
echo "[paseo] starting daemon on ${PASEO_LISTEN} with web UI ${PASEO_WEB_UI_ENABLED}"
if [[ "$(id -u)" == "0" && "$PASEO_RUNTIME_USER" == "paseo" ]]; then
  exec gosu paseo node "$entry"
fi
exec node "$entry"
