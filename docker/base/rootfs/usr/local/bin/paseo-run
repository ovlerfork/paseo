#!/command/with-contenv bash
# Launch the Paseo daemon (supervisor entrypoint) in the foreground.
set -euo pipefail

IMAGE_DEFAULT_HOME="/home/paseo"
IMAGE_DEFAULT_PASEO_HOME="${IMAGE_DEFAULT_HOME}/.paseo"
PASEO_RUNTIME_USER="${PASEO_RUNTIME_USER:-paseo}"
if [[ "$PASEO_RUNTIME_USER" == "root" && "${HOME:-$IMAGE_DEFAULT_HOME}" == "$IMAGE_DEFAULT_HOME" ]]; then
  HOME="/root"
else
  : "${HOME:=$IMAGE_DEFAULT_HOME}"
fi
if [[ -z "${PASEO_HOME:-}" || ( "$HOME" != "$IMAGE_DEFAULT_HOME" && "${PASEO_HOME:-}" == "$IMAGE_DEFAULT_PASEO_HOME" ) ]]; then
  PASEO_HOME="${HOME}/.paseo"
fi
export HOME
export PASEO_HOME

home_scoped_env() {
  local name="$1"
  local suffix="$2"
  local image_default="${IMAGE_DEFAULT_HOME}${suffix}"
  local value="${!name:-}"
  if [[ -z "$value" || ( "$HOME" != "$IMAGE_DEFAULT_HOME" && "$value" == "$image_default" ) ]]; then
    printf -v "$name" '%s' "${HOME}${suffix}"
  fi
  export "$name"
}

home_scoped_env CLAUDE_CONFIG_DIR "/.claude"
home_scoped_env CODEX_HOME "/.codex"
home_scoped_env XDG_CONFIG_HOME "/.config"
home_scoped_env XDG_DATA_HOME "/.local/share"
home_scoped_env XDG_STATE_HOME "/.local/state"
home_scoped_env XDG_CACHE_HOME "/.cache"

: "${PASEO_LISTEN:=0.0.0.0:6767}"
export PASEO_LISTEN

: "${PASEO_LOG_LEVEL:=warn}"
export PASEO_LOG_LEVEL

if [[ -z "${PASEO_PASSWORD:-}" ]]; then
  echo "[paseo] WARNING: PASEO_PASSWORD is not set." >&2
  echo "[paseo] The daemon will accept connections without a password." >&2
  echo "[paseo] Set -e PASEO_PASSWORD=... for any network-reachable deployment." >&2
fi

if [[ ! -f /etc/paseo-server-entry ]]; then
  echo "[paseo] FATAL: /etc/paseo-server-entry missing (broken image build)." >&2
  exit 1
fi

ENTRY="$(cat /etc/paseo-server-entry)"
echo "[paseo] starting daemon: node ${ENTRY} (listen ${PASEO_LISTEN}, home ${PASEO_HOME})"
exec node "$ENTRY"
