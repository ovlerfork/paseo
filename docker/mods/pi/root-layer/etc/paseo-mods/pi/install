#!/command/with-contenv bash
# Install the Pi coding agent so Paseo exposes the `pi` provider.
#
# Paseo only needs the `pi` binary on PATH (it talks to it via `pi --mode rpc`).
# The repo does not pin Pi's package, so the npm package name is overridable
# with the PI_NPM_PACKAGE env var if the default ever changes upstream.
set -euo pipefail

if command -v pi >/dev/null 2>&1; then
  echo "[mod:pi] pi already on PATH — skipping install."
  exit 0
fi

PI_NPM_PACKAGE="${PI_NPM_PACKAGE:-@earendil-works/pi-coding-agent}"
echo "[mod:pi] installing ${PI_NPM_PACKAGE}"
npm install -g --ignore-scripts "${PI_NPM_PACKAGE}"

PI_BIN="$(command -v pi)" || {
  echo "[mod:pi] ERROR: ${PI_NPM_PACKAGE} did not install a 'pi' binary on PATH." >&2
  exit 1
}

echo "[mod:pi] done (${PI_BIN})"
