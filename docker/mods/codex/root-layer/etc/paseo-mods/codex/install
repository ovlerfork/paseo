#!/usr/bin/env bash
set -euo pipefail

ensure_agent_thread_cap() {
  local codex_home="${PASEO_USER_CODEX_HOME:-${CODEX_HOME:-${HOME}/.codex}}"
  local config_file="${codex_home}/config.toml"

  mkdir -p "$codex_home"
  python3 - "$config_file" <<'PY'
from pathlib import Path
import re
import sys

path = Path(sys.argv[1])
existed = path.exists()
text = path.read_text() if existed else ""

section_re = re.compile(r"(?m)^\s*\[agents\]\s*(?:#.*)?$")
header_re = re.compile(r"(?m)^\s*\[[^\]]+\]\s*(?:#.*)?$")
max_threads_re = re.compile(
    r"(?m)^(\s*max_threads\s*=\s*)[^#\n]*(\s*(?:#.*)?)$"
)

section = section_re.search(text)
if section:
    next_header = header_re.search(text, section.end())
    section_end = next_header.start() if next_header else len(text)
    body = text[section.end():section_end]
    if max_threads_re.search(body):
        body = max_threads_re.sub(r"\g<1>64\2", body)
    else:
        body = "\nmax_threads = 64" + body
    updated = text[: section.end()] + body + text[section_end:]
else:
    separator = ""
    if text and not text.endswith("\n"):
        separator = "\n\n"
    elif text and not text.endswith("\n\n"):
        separator = "\n"
    updated = f"{text}{separator}[agents]\nmax_threads = 64\n"

if updated != text:
    path.write_text(updated)
    if not existed:
        path.chmod(0o600)
PY

  if [[ "$(id -u)" == "0" && "${PASEO_RUNTIME_USER:-paseo}" == "paseo" ]]; then
    chown -R paseo:paseo "$codex_home"
  fi
  echo "[mod:codex] ensured agents.max_threads=64 in ${config_file}"
}

ensure_agent_thread_cap

if command -v codex >/dev/null 2>&1; then
  echo "[mod:codex] codex already on PATH; skipping install."
  exit 0
fi

package="@openai/codex"
version_file="/etc/paseo-mods/codex/package-version"
if [[ -r "$version_file" ]]; then
  version="$(tr -d '[:space:]' < "$version_file")"
  if [[ -n "$version" ]]; then
    package="${package}@${version}"
  fi
fi

echo "[mod:codex] installing ${package} with pnpm"
paseo-mod-install node "$package"
echo "[mod:codex] done ($(command -v codex))"
